    head "Beschikbare presets"
    local eras=("1960s" "1970s" "Home computers 1977–1983" "IBM PC tijdperk 1981–1990"
                "Amiga / Mac / NeXT / UNIX 1984–1991" "Late DOS / SVGA 1990–1995"
                "Film en Science Fiction")
    local era_keys=(
        "IBM2260"
        "DEC_GT40 DEC_VT100 IBM3270 WYSE50 RADAR TELETEXT"
        "APPLE_II ATARI800 BBC_MICRO VIC20 ZX_SPECTRUM C64 MSX"
        "IBM_MDA IBM_CGA IBM_EGA TANDY1000 IBM_VGA"
        "AMIGA500 AMIGA_WB MAC128 NEXT_STATION SUN3"
        "SVGA TRINITRON"
        "HAL9000 ALIEN WARGAMES BLADE_RUNNER MATRIX"
    )
    for i in "${!eras[@]}"; do
        echo -e "\n  ${BOLD}${C}── ${eras[$i]}${NC}"
        for key in ${era_keys[$i]}; do
            if [[ -n "${PRESET_DATA[$key]+_}" ]]; then
                IFS='|' read -r naam era font fsize params <<< "${PRESET_DATA[$key]}"
                printf "  ${BOLD}%-18s${NC}  %-42s  ${DIM}%s${NC}\n" "$key" "$naam" "$font"
            fi
        done
    done
    echo ""
    msg "  Gebruik: ${BOLD}retro-term preset <SLEUTEL>${NC}"
    msg "  Voorbeeld: ${BOLD}retro-term preset IBM_VGA${NC}"
    echo ""
}


# ── Font-size berekening op basis van venstergrootte ──────────────────────────
# Gegeven de originele resolutie (bv. 320×200) en de huidige venstergrootte,
# bereken de optimale font-size zodat de terminal precies op die resolutie past.
#
# Redenering: een 320×200-systeem gebruikte typisch 40-col × 25-rij tekenmodus.
# font_size = venster_hoogte / aantal_rijen_origineel
# Wij benaderen aantal_rijen als: originele_hoogte / gemiddelde_cel_hoogte (8px)
#
# Args: $1=resX $2=resY
# Output: font_size_pt (integer, minimaal 8)
calc_font_size() {
    local resX="${1:-320}" resY="${2:-200}"
    if [[ "$resX" == "0" || "$resY" == "0" ]]; then
        echo "14"  # default als geen resolutie bekend
        return
    fi

    # Haal de venstergrootte op via xdpyinfo of xwininfo op het actieve venster
    local win_h=0
    # Probeer via xdotool (meest betrouwbaar)
    if command -v xdotool &>/dev/null; then
        local wid
        wid=$(xdotool getactivewindow 2>/dev/null || echo "")
        if [[ -n "$wid" ]]; then
            local geom
            geom=$(xdotool getwindowgeometry "$wid" 2>/dev/null || echo "")
            win_h=$(echo "$geom" | grep -oP 'Geometry: \K\d+x\d+' | cut -dx -f2 || echo "0")
        fi
    fi

    # Fallback: gebruik schermhoogte als proxy (conservatief: neem 80% aan voor venster)
    if [[ "$win_h" -lt 100 ]]; then
        local screen_h
        screen_h=$(xdpyinfo 2>/dev/null | grep dimensions | grep -oP '\d+x\d+' | head -1 | cut -dx -f2 || echo "1080")
        win_h=$(( screen_h * 80 / 100 ))
    fi

    # Schat aantal rijen: originele hoogte gedeeld door geschatte celgrootte
    # Celgrootte = originele pixelhoogte / 25 rijen (standaard tekstmodus)
    local rows=$(( resY / 8 ))  # 8px per rij is historische norm
    [[ "$rows" -lt 1 ]] && rows=25

    # Bereken font-size: venster_hoogte / aantal_rijen (in points, 1pt ≈ 1.33px bij 96dpi)
    local size_px=$(( win_h / rows ))
    local size_pt=$(( size_px * 3 / 4 ))  # px naar pt bij 96dpi

    # Grenzen: minimaal 8, maximaal 32
    [[ "$size_pt" -lt 8  ]] && size_pt=8
    [[ "$size_pt" -gt 32 ]] && size_pt=32

    echo "$size_pt"
}

set_konsole_font() {
    local font="$1" size="$2"
    mkdir -p "$KONSOLE_DIR"
    local pfile="$KONSOLE_DIR/Retro Terminal.profile"

    # Maak profiel aan of werk het bij
    if [[ ! -f "$pfile" ]]; then
        cat > "$pfile" <<EOF
[Appearance]
Font=${font},${size},-1,5,50,0,0,0,0,0

[General]
Name=Retro Terminal
Parent=FALLBACK/
EOF
    else
        if grep -q "^Font=" "$pfile"; then
            sed -i "s|^Font=.*|Font=${font},${size},-1,5,50,0,0,0,0,0|" "$pfile"
        else
            sed -i "/\[Appearance\]/a Font=${font},${size},-1,5,50,0,0,0,0,0" "$pfile"
        fi
    fi

    # Probeer directe D-Bus aanroep op actieve Konsole-sessies
    local svc
    svc=$(qdbus6 2>/dev/null | grep -i konsole | head -1 ||
          qdbus  2>/dev/null | grep -i konsole | head -1 || echo "")
    if [[ -n "$svc" ]]; then
        local sessions
        sessions=$(qdbus6 "$svc" 2>/dev/null | grep "^/Sessions/" ||
                   qdbus  "$svc" 2>/dev/null | grep "^/Sessions/" || true)
        while read -r ses; do
            qdbus6 "$svc" "$ses" org.kde.konsole.Session.setFont "$font" "$size" 2>/dev/null ||
            qdbus  "$svc" "$ses" org.kde.konsole.Session.setFont "$font" "$size" 2>/dev/null || true
        done <<< "$sessions"
    fi
}

cmd_preset() {
    local key="${1:-}"
    [[ -z "$key" ]] && { err "Geen preset opgegeven."; cmd_presets; return 1; }
    [[ -z "${PRESET_DATA[$key]+_}" ]] && { err "Onbekende preset: $key"; cmd_presets; return 1; }

    IFS='|' read -r naam era font fsize params resX resY <<< "${PRESET_DATA[$key]}"
    resX="${resX:-0}" resY="${resY:-0}"

    head "Preset: $naam"
    msg "  ${DIM}$era${NC}"
    echo ""

    # KWin parameters schrijven
    for pair in $params; do
        kwrite "${pair%%=*}" "${pair#*=}"
    done
    kwrite "activePreset" "$key"

    # Pixel scaling: targetResX/Y zitten al in de params-string en worden
    # via de for-loop hierboven weggeschreven naar kwinrc.
    # Toon een info-bericht als de resolutie bekend is.
    if [[ "$resX" != "0" && "$resY" != "0" ]]; then
        info "Originele resolutie: ${BOLD}${resX}×${resY}${NC}"
        info "Pixel scaling: ${DIM}retro-term set pixelScale 1.0  (0.0=uit, 1.0=pixel-exact)${NC}"
    fi

    # Font instellen — bereken optimale grootte als resolutie bekend is
    local actual_fsize="$fsize"
    if [[ "$resX" != "0" && "$resY" != "0" ]]; then
        local calc_size
        calc_size=$(calc_font_size "$resX" "$resY")
        if [[ "$calc_size" -ne "$fsize" ]]; then
            info "Font: ${BOLD}$font${NC} — opgegeven: ${fsize}pt, berekend voor ${resX}×${resY}: ${BOLD}${calc_size}pt${NC}"
            actual_fsize="$calc_size"
        fi
    fi
    info "Font: ${BOLD}$font${NC} (${actual_fsize}pt)"
    set_konsole_font "$font" "$actual_fsize"


    if font_present "$font"; then
        ok "Font aanwezig"
    else
        warn "Font '${font}' niet gevonden — installeer met: ${BOLD}retro-term install-fonts${NC}"
    fi

    kwin_reload
    ok "Preset '$naam' actief"
}

