    else msg "  $TICK int10h extra fonts (Kaypro/Compaq/DEC/TeleVideo/Amstrad/NEC/HP — al aanwezig)"; fi
    # ── Afronden ─────────────────────────────────────────────────────────────
    echo ""
    info "Fontcache bijwerken…"
    fc-cache -fv "$FONT_DIR" 2>/dev/null | tail -2 || fc-cache -f
    local n; n=$(find "$FONT_DIR" \( -name "*.ttf" -o -name "*.otf" \) 2>/dev/null | wc -l)
    ok "$n font-bestanden geïnstalleerd in $FONT_DIR"
    echo ""
    cmd_install_fonts --status
}

