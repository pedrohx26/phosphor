        unzip -q "$TMP/amtreasure.zip" -d "$TMP/amtreasure/" 2>/dev/null && \
        find "$TMP/amtreasure/" \( -name "*.ttf" -o -name "*.otf" \) -exec cp {} "$FONT_DIR/" \; && \
        ok "Another Man's Treasure (TRS-80 Model I/III) geïnstalleerd" || \
        warn "TRS-80 font mislukt → https://www.kreativekorp.com/software/fonts/retro/"
    else msg "  $TICK Another Man's Treasure / TRS-80 font (al aanwezig)"; fi

    # Hot CoCo (TRS-80 CoCo), Lisa, Shaston, Mizuno, Antiquarius, Project Jason
    for kreative_pkg in \
        "Hot CoCo:hotcoco:TRS-80 CoCo" \
        "LisaTerminal:lisa1:Apple Lisa" \
        "Shaston:shaston:Apple IIgs GS/OS" \
        "Mizuno:mizuno:Sharp MZ-700" \
        "Antiquarius:aq2:Mattel Aquarius" \
        "Project Jason:projason:Atari ST"
    do
        IFS=':' read -r font_name pkg_name desc <<< "$kreative_pkg"
        if ! font_present "$font_name"; then
            info "16/17 — Kreativekorp: $font_name ($desc)"
            download "https://www.kreativekorp.com/swdownload/fonts/retro/${pkg_name}.zip" \
                     "$TMP/${pkg_name}.zip" "$font_name" && \
            unzip -q "$TMP/${pkg_name}.zip" -d "$TMP/${pkg_name}/" 2>/dev/null && \
            find "$TMP/${pkg_name}/" \( -name "*.ttf" -o -name "*.otf" \) -exec cp {} "$FONT_DIR/" \; && \
            ok "$font_name ($desc) geïnstalleerd" || \
            warn "$font_name mislukt → https://www.kreativekorp.com/software/fonts/retro/"
        else msg "  $TICK $font_name (al aanwezig)"; fi
    done

    # ── 17. int10h extra fonts (Kaypro, Compaq, DEC Rainbow, TeleVideo, ────────
    #        Amstrad, NEC APC3, HP 150) — onderdeel van de oldschool PC font pack
    # Het int10h pack (al geïnstalleerd in stap 2) bevat ALLE benodigde fonts.
    # Aparte download alleen nodig als stap 2 mislukte.
    if ! font_present "Kaypro" && ! font_present "PxPlus Kaypro"; then
        warn "17/17 — Kaypro/Compaq/DEC/TeleVideo/Amstrad/NEC/HP fonts niet gevonden"
