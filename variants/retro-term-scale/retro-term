cmd_install_fonts() {
    local status_only=0
    [[ "${1:-}" == "--status" ]] && status_only=1

    if [[ $status_only -eq 1 ]]; then
        head "Font-status"
        declare -A FMAP=(
            ["PxPlus IBM VGA"]="IBM_VGA, IBM_EGA, IBM_CGA, IBM_MDA, IBM3270, TANDY1000, WYSE50"
            ["VT323"]="DEC_VT100, DEC_GT40, ZX_SPECTRUM, MSX, WARGAMES, MATRIX"
            ["Topaz Unicode"]="AMIGA500, AMIGA_WB"
            ["C64 Pro Mono"]="C64, VIC20"
            ["Share Tech Mono"]="RADAR, HAL9000, ALIEN, MATRIX"
            ["Terminus"]="SVGA, TRINITRON"
            ["Courier Prime"]="BLADE_RUNNER"
            ["Silkscreen"]="MAC128"
            ["Bedstead"]="TELETEXT, BBC_MICRO"
            ["Glass TTY VT220"]="IBM2260"
            ["Print Char 21"]="APPLE_II"
            ["Atari Classic"]="ATARI800"
            ["Lucida Console"]="NEXT_STATION, SUN3"
        )
        local ok_n=0 miss_n=0
        printf "\n  %-30s %-35s %s\n" "FONT" "PRESETS" "STATUS"
        printf "  %-30s %-35s %s\n" "──────────────────────────────" "───────────────────────────────────" "──────────"
        for font in "${!FMAP[@]}"; do
            local presets="${FMAP[$font]}"
            if font_present "${font%% *}"; then
                printf "  ${G}✓${NC} %-28s %-35s ${G}aanwezig${NC}\n" "$font" "$presets"
                ((ok_n++))
            else
                printf "  ${R}✗${NC} %-28s %-35s ${R}ontbreekt${NC}\n" "$font" "$presets"
                ((miss_n++))
            fi
        done | sort
        echo ""
        msg "  ${G}✓ Aanwezig: $ok_n${NC}   ${R}✗ Ontbreekt: $miss_n${NC}"
        echo ""
        return 0
    fi

    head "Fonts installeren voor alle presets"
    need curl curl; need unzip unzip; need fc-cache fontconfig

    mkdir -p "$FONT_DIR"
    local TMP; TMP=$(mktemp -d /tmp/retro-fonts.XXXXXX)
    trap "rm -rf $TMP" EXIT

    install_if_missing() {
        local font_check="$1" name="$2"
        if font_present "$font_check"; then
            msg "  $TICK $name ${DIM}(al aanwezig)${NC}"
            return 1
        fi
        info "Installeren: $name"
        return 0
    }

    # ── 1. Terminus (pacman) ─────────────────────────────────────────────────
    if ! font_present "Terminus"; then
        info "1/13 — Terminus (pacman)"
        sudo pacman -S --needed --noconfirm terminus-font 2>/dev/null || true
        has yay && yay -S --needed --noconfirm ttf-terminus-nerd 2>/dev/null || true
    else msg "  $TICK Terminus (al aanwezig)"; fi

    # ── 2. int10h Oldschool PC Font Pack ─────────────────────────────────────
    if ! font_present "PxPlus"; then
        info "2/13 — int10h Oldschool PC Font Pack (IBM MDA/CGA/EGA/VGA/Tandy/Wyse/3270)"
        if has yay && yay -Ss "ttf-oldschool-pc-font" 2>/dev/null | grep -q "ttf-oldschool"; then
            yay -S --needed --noconfirm ttf-oldschool-pc-font-pack 2>/dev/null && ok "int10h via AUR" || true
        fi
        if ! font_present "PxPlus"; then
            download "https://int10h.org/oldschool-pc-fonts/files/oldschool_pc_font_pack_v2.2.zip" \
                     "$TMP/int10h.zip" "int10h Pack v2.2" && \
            unzip -q "$TMP/int10h.zip" -d "$TMP/int10h/" 2>/dev/null && \
            find "$TMP/int10h/" -name "*.ttf" -exec cp {} "$FONT_DIR/" \; && \
            ok "int10h Pack geïnstalleerd" || \
            warn "int10h download mislukt → handmatig: https://int10h.org/oldschool-pc-fonts/"
        fi
    else msg "  $TICK int10h Oldschool PC Font Pack (al aanwezig)"; fi

    # ── 3. Amiga Topaz ───────────────────────────────────────────────────────
    if ! font_present "Topaz"; then
        info "3/13 — Amiga Topaz Unicode"
        if has git; then
            git clone --depth=1 -q https://github.com/rewtnull/amigafonts.git "$TMP/amiga" 2>/dev/null || \
            download "https://github.com/rewtnull/amigafonts/archive/refs/heads/master.zip" \
                     "$TMP/amiga.zip" "Amiga fonts" && \
            unzip -q "$TMP/amiga.zip" -d "$TMP/" 2>/dev/null || true
            local adir; adir=$(find "$TMP" -maxdepth 2 -type d -name "amigafonts*" | head -1)
            [[ -n "$adir" ]] && find "$adir" \( -name "*.ttf" -o -name "*.otf" \) -exec cp {} "$FONT_DIR/" \;
        fi
        font_present "Topaz" && ok "Topaz geïnstalleerd" || warn "Topaz mislukt → https://github.com/rewtnull/amigafonts"
    else msg "  $TICK Topaz Unicode (al aanwezig)"; fi

    # ── 4. C64 Pro Mono ──────────────────────────────────────────────────────
    if ! font_present "C64"; then
        info "4/13 — C64 Pro Mono"
        has yay && yay -S --needed --noconfirm ttf-c64-truetype 2>/dev/null || true
        if ! font_present "C64"; then
            download "https://style64.org/file/C64_TrueType_v1.2.1-(STYLE).zip" \
                     "$TMP/c64.zip" "C64 Pro Mono" && \
            unzip -q "$TMP/c64.zip" -d "$TMP/c64/" && \
            find "$TMP/c64/" -name "*.ttf" -exec cp {} "$FONT_DIR/" \; || \
            download "https://github.com/statico/dotfiles/raw/master/.fonts/C64_Pro_Mono.ttf" \
                     "$FONT_DIR/C64_Pro_Mono.ttf" "C64 Pro Mono (enkel bestand)" || \
            warn "C64 Pro Mono mislukt → https://style64.org/c64-truetype"
        fi
    else msg "  $TICK C64 Pro Mono (al aanwezig)"; fi

    # ── 5. VT323 ─────────────────────────────────────────────────────────────
    if ! font_present "VT323"; then
        info "5/13 — VT323 (DEC terminal stijl)"
        download "https://github.com/googlefonts/vt323/raw/main/fonts/VT323-Regular.ttf" \
                 "$FONT_DIR/VT323-Regular.ttf" "VT323" && ok "VT323 geïnstalleerd" || \
        warn "VT323 mislukt → https://fonts.google.com/specimen/VT323"
    else msg "  $TICK VT323 (al aanwezig)"; fi

    # ── 6. Share Tech Mono ───────────────────────────────────────────────────
    if ! font_present "ShareTechMono" && ! font_present "Share Tech"; then
        info "6/13 — Share Tech Mono"
        download "https://github.com/googlefonts/sharetechmono/raw/main/fonts/ShareTechMono-Regular.ttf" \
                 "$FONT_DIR/ShareTechMono-Regular.ttf" "Share Tech Mono" && ok "Share Tech Mono geïnstalleerd" || \
        warn "Share Tech Mono mislukt → https://fonts.google.com/specimen/Share+Tech+Mono"
    else msg "  $TICK Share Tech Mono (al aanwezig)"; fi

    # ── 7. Courier Prime ─────────────────────────────────────────────────────
    if ! font_present "CourierPrime" && ! font_present "Courier Prime"; then
        info "7/13 — Courier Prime"
        download "https://github.com/googlefonts/courier-prime/raw/main/fonts/ttf/CourierPrime-Regular.ttf" \
                 "$FONT_DIR/CourierPrime-Regular.ttf" "Courier Prime" && ok "Courier Prime geïnstalleerd" || \
        warn "Courier Prime mislukt → https://fonts.google.com/specimen/Courier+Prime"
    else msg "  $TICK Courier Prime (al aanwezig)"; fi

    # ── 8. Silkscreen ────────────────────────────────────────────────────────
    if ! font_present "Silkscreen"; then
        info "8/13 — Silkscreen (Apple Mac 128K)"
        download "https://github.com/googlefonts/Silkscreen/raw/main/fonts/ttf/Silkscreen-Regular.ttf" \
                 "$FONT_DIR/Silkscreen-Regular.ttf" "Silkscreen" && \
        download "https://github.com/googlefonts/Silkscreen/raw/main/fonts/ttf/Silkscreen-Bold.ttf" \
                 "$FONT_DIR/Silkscreen-Bold.ttf" "Silkscreen Bold" && ok "Silkscreen geïnstalleerd" || \
        warn "Silkscreen mislukt → https://kottke.org/plus/type/silkscreen/"
    else msg "  $TICK Silkscreen (al aanwezig)"; fi

    # ── 9. Bedstead ──────────────────────────────────────────────────────────
    if ! font_present "Bedstead"; then
        info "9/13 — Bedstead (Teletext / BBC Micro)"
        download "https://bjh21.me.uk/bedstead/bedstead.otf" \
                 "$FONT_DIR/bedstead.otf" "Bedstead" && ok "Bedstead geïnstalleerd" || \
        warn "Bedstead mislukt → https://bjh21.me.uk/bedstead/"
    else msg "  $TICK Bedstead (al aanwezig)"; fi

    # ── 10. Print Char 21 ────────────────────────────────────────────────────
    if ! font_present "Print Char"; then
        info "10/13 — Print Char 21 (Apple II)"
        download "https://www.kreativekorp.com/swdownload/fonts/Print_Char_21.zip" \
                 "$TMP/pc21.zip" "Print Char 21" && \
        unzip -q "$TMP/pc21.zip" -d "$TMP/pc21/" && \
        find "$TMP/pc21/" \( -name "*.ttf" -o -name "*.otf" \) -exec cp {} "$FONT_DIR/" \; && \
        ok "Print Char 21 geïnstalleerd" || \
        warn "Print Char 21 mislukt → https://www.kreativekorp.com/software/fonts/apple2/"
    else msg "  $TICK Print Char 21 (al aanwezig)"; fi

    # ── 11. Atari Classic ────────────────────────────────────────────────────
    if ! font_present "Atari"; then
        info "11/13 — Atari Classic (Atari 400/800)"
        has yay && yay -S --needed --noconfirm ttf-atari-classic 2>/dev/null || true
        if ! font_present "Atari"; then
            download "https://github.com/AtariAge/AtariFont/raw/main/AtariClassic-Regular.ttf" \
                     "$FONT_DIR/AtariClassic-Regular.ttf" "Atari Classic" && ok "Atari Classic geïnstalleerd" || \
            warn "Atari Classic mislukt → https://www.dafont.com/atari-classic.font"
        fi
    else msg "  $TICK Atari Classic (al aanwezig)"; fi

    # ── 12. Glass TTY ────────────────────────────────────────────────────────
    if ! font_present "Glass"; then
        info "12/13 — Glass TTY VT220 (IBM 2260 mainframe)"
        download "https://github.com/svofski/glasstty/raw/master/GlassTTYVT220.ttf" \
                 "$FONT_DIR/GlassTTYVT220.ttf" "Glass TTY VT220" && ok "Glass TTY geïnstalleerd" || \
        warn "Glass TTY mislukt → https://github.com/svofski/glasstty"
    else msg "  $TICK Glass TTY VT220 (al aanwezig)"; fi

    # ── 13. Unscii (BBC Micro / Mode 7 achtige) ──────────────────────────────
    if ! font_present "unscii" && ! font_present "Unscii"; then
        info "13/13 — Unscii (BBC Micro / Mode 7)"
        download "https://github.com/viznut/unscii/raw/master/unscii-16-full.ttf" \
                 "$FONT_DIR/unscii-16-full.ttf" "Unscii-16" && ok "Unscii geïnstalleerd" || \
        warn "Unscii mislukt → http://viznut.fi/unscii/"
    else msg "  $TICK Unscii/Mode7 (al aanwezig)"; fi


    # ── 14. Kreativekorp Retro Pack ───────────────────────────────────────────
    # Bevat: Pet Me (Commodore PET), Another Man's Treasure (TRS-80 Model I/III),
    #        Hot CoCo (TRS-80 CoCo), LisaTerminal Paper (Apple Lisa),
    #        Shaston (Apple IIgs), Mizuno (Sharp MZ), Antiquarius (Mattel Aquarius),
    #        Project Jason (Atari ST), Speccy (ZX Spectrum extra)
    if ! font_present "Pet Me" && ! font_present "PetMe"; then
        info "14/17 — Kreativekorp: Pet Me (Commodore PET)"
        download "https://www.kreativekorp.com/swdownload/fonts/retro/petme.zip" \
                 "$TMP/petme.zip" "Pet Me" && \
        unzip -q "$TMP/petme.zip" -d "$TMP/petme/" 2>/dev/null && \
        find "$TMP/petme/" \( -name "*.ttf" -o -name "*.otf" \) -exec cp {} "$FONT_DIR/" \; && \
        ok "Pet Me (Commodore PET) geïnstalleerd" || \
        warn "Pet Me mislukt → https://www.kreativekorp.com/software/fonts/retro/"
    else msg "  $TICK Pet Me / Commodore PET font (al aanwezig)"; fi

    if ! font_present "Another Man" && ! font_present "AnotherMan"; then
