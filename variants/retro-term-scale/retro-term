# KWIN EFFECT JS — ingebed als heredoc
# ══════════════════════════════════════════════════════════════════════════════
write_effect_js() {
    cat > "$EFFECT_DIR/contents/code/main.js" <<'JSEOF'
/*
 * SPDX-License-Identifier: GPL-2.0-or-later
 * retro-term — KWin CRT Effect
 */
"use strict";

const DEFAULTS = {
    targetClasses:"konsole,cool-retro-term,yakuake,kitty,alacritty",
    phosphorType:1, phosphorAgeing:0.05, colorTemperature:7000, phosphorPersistence:0.10,
    screenCurvature:0.25, vignetteIntensity:0.35, ambientReflection:0.04,
    rasterizationMode:1, scanlinesIntensity:0.35, scanlinesSharpness:0.50,
    bloom:0.55, glowingLine:0.20, brightness:0.50, contrast:0.80,
    staticNoise:0.08, jitter:0.10, syncMode:0, horizontalSync:0.05,
    flickering:0.08, ghostingIntensity:0.00,
    chromaColor:0.20, saturationColor:0.20, rbgShift:0.10,
    characterSmearing:0.08, burnIn:0.20,
    warmupEnabled:true, warmupDuration:8.0,
    degaussOnStart:true, degaussDuration:2.5,
};

function RetroTerminalEffect() {
    this._warmupTime = {}; this._degaussTime = {};
    this._startTime  = Date.now();
    this._cfg = Object.assign({}, DEFAULTS);
    this._loadConfig();
    this._targetSet = new Set(this._cfg.targetClasses.toLowerCase().split(",").map(s=>s.trim()));
    this._shader = effects.loadFragmentShader(
        __KWINDIR__ + "/../kwin/effects/retro-terminal/contents/shaders/retro.frag");
    if (!this._shader) { print("[retro-terminal] ERROR: shader niet geladen"); return; }
    effects.windowAdded.connect(this._windowAdded.bind(this));
    effects.windowClosed.connect(this._windowClosed.bind(this));
    effects.paintWindow.connect(this._paintWindow.bind(this));
    effects.prePaintScreen.connect(this._prePaintScreen.bind(this));
    effects.windowList().forEach(w => this._windowAdded(w));
    print("[retro-terminal] Geladen. Doelwitten: " + this._cfg.targetClasses);
}

RetroTerminalEffect.prototype._loadConfig = function() {
    const rF = k => { const v=effects.readConfig(k,null); return v!==null?parseFloat(v):null; };
    const rI = k => { const v=effects.readConfig(k,null); return v!==null?parseInt(v):null; };
    const rB = k => { const v=effects.readConfig(k,null); return v!==null?(v==="true"||v===true):null; };
    const rS = k => effects.readConfig(k,null);
    const c  = this._cfg;
    const a  = (k,v) => { if(v!==null) c[k]=v; };
    a("targetClasses",rS("targetClasses")); a("phosphorType",rI("phosphorType"));
    a("phosphorAgeing",rF("phosphorAgeing")); a("colorTemperature",rF("colorTemperature"));
    a("phosphorPersistence",rF("phosphorPersistence")); a("screenCurvature",rF("screenCurvature"));
    a("vignetteIntensity",rF("vignetteIntensity")); a("ambientReflection",rF("ambientReflection"));
    a("rasterizationMode",rI("rasterizationMode")); a("scanlinesIntensity",rF("scanlinesIntensity"));
    a("scanlinesSharpness",rF("scanlinesSharpness")); a("bloom",rF("bloom"));
    a("glowingLine",rF("glowingLine")); a("brightness",rF("brightness")); a("contrast",rF("contrast"));
    a("staticNoise",rF("staticNoise")); a("jitter",rF("jitter")); a("syncMode",rI("syncMode"));
    a("horizontalSync",rF("horizontalSync")); a("flickering",rF("flickering"));
    a("ghostingIntensity",rF("ghostingIntensity")); a("chromaColor",rF("chromaColor"));
    a("saturationColor",rF("saturationColor")); a("rbgShift",rF("rbgShift"));
    a("characterSmearing",rF("characterSmearing")); a("burnIn",rF("burnIn"));
    a("warmupEnabled",rB("warmupEnabled")); a("warmupDuration",rF("warmupDuration"));
    a("degaussOnStart",rB("degaussOnStart")); a("degaussDuration",rF("degaussDuration"));
};

RetroTerminalEffect.prototype._isTarget = function(w) {
    const cls=(w.windowClass||"").toLowerCase();
    for(let c of this._targetSet) if(cls.indexOf(c)!==-1) return true;
    return false;
};
RetroTerminalEffect.prototype._windowAdded = function(w) {
    if(!this._isTarget(w)) return;
    this._warmupTime[w.windowId]=0.0; this._degaussTime[w.windowId]=0.0;
};
RetroTerminalEffect.prototype._windowClosed = function(w) {
    delete this._warmupTime[w.windowId]; delete this._degaussTime[w.windowId];
};
RetroTerminalEffect.prototype._prePaintScreen = function(data,delta) {
    const ds=delta/1000.0; const cfg=this._cfg;
    for(let id in this._warmupTime) {
        if(this._warmupTime[id]<cfg.warmupDuration){
            this._warmupTime[id]=Math.min(this._warmupTime[id]+ds,cfg.warmupDuration);
            effects.addRepaintFull();
        }
        if(this._degaussTime[id]<cfg.degaussDuration){
            this._degaussTime[id]=Math.min(this._degaussTime[id]+ds,cfg.degaussDuration);
            effects.addRepaintFull();
        }
    }
    if(cfg.staticNoise>0.001||cfg.flickering>0.001||cfg.jitter>0.001||cfg.syncMode!==0)
        effects.addRepaintFull();
    effects.prePaintScreen(data,delta);
};
RetroTerminalEffect.prototype._paintWindow = function(w,mask,region) {
    if(!this._isTarget(w)){effects.paintWindow(w,mask,region);return;}
    const id=w.windowId; const cfg=this._cfg;
    const now=(Date.now()-this._startTime)/1000.0;
    const wp=cfg.warmupEnabled?Math.min((this._warmupTime[id]||0)/cfg.warmupDuration,1.0):1.0;
    const dp=cfg.degaussOnStart?Math.min((this._degaussTime[id]||0)/cfg.degaussDuration,1.0):1.0;
    effects.setShader(this._shader);
    const gl=this._shader; const geo=w.geometry;
    gl.setUniform("resolution",[geo.width,geo.height]); gl.setUniform("time",now);
    gl.setUniform("phosphorType",cfg.phosphorType); gl.setUniform("phosphorAgeing",cfg.phosphorAgeing);
    gl.setUniform("colorTemperature",cfg.colorTemperature); gl.setUniform("phosphorPersistence",cfg.phosphorPersistence);
    gl.setUniform("screenCurvature",cfg.screenCurvature); gl.setUniform("vignetteIntensity",cfg.vignetteIntensity);
    gl.setUniform("ambientReflection",cfg.ambientReflection); gl.setUniform("rasterizationMode",cfg.rasterizationMode);
    gl.setUniform("scanlinesIntensity",cfg.scanlinesIntensity); gl.setUniform("scanlinesSharpness",cfg.scanlinesSharpness);
    gl.setUniform("bloom",cfg.bloom); gl.setUniform("glowingLine",cfg.glowingLine);
    gl.setUniform("brightness",cfg.brightness); gl.setUniform("contrast",cfg.contrast);
    gl.setUniform("staticNoise",cfg.staticNoise); gl.setUniform("jitter",cfg.jitter);
    gl.setUniform("syncMode",cfg.syncMode); gl.setUniform("horizontalSync",cfg.horizontalSync);
    gl.setUniform("flickering",cfg.flickering); gl.setUniform("ghostingIntensity",cfg.ghostingIntensity);
    gl.setUniform("chromaColor",cfg.chromaColor); gl.setUniform("saturationColor",cfg.saturationColor);
    gl.setUniform("rbgShift",cfg.rbgShift); gl.setUniform("characterSmearing",cfg.characterSmearing);
    gl.setUniform("burnIn",cfg.burnIn);
    gl.setUniform("warmupProgress",wp); gl.setUniform("degaussProgress",dp<1.0?dp:0.0);
    effects.paintWindow(w,mask,region);
    effects.setShader(null);
};

new RetroTerminalEffect();
JSEOF
}

