  ghostingIntensity   float 0.0–0.5  Frame-echo (alleen bij syncMode=3)

KLEUR & OPTIEK
  chromaColor         float 0.0–1.0  Kleurretentie (0=grijsschaal, 1=kleur)
  saturationColor     float 0.0–1.0  Extra kleurverzadiging
  rbgShift            float 0.0–1.0  Chromatische aberratie
  characterSmearing   float 0.0–1.0  Horizontale tekenvervaging
  burnIn              float 0.0–1.0  Fosfor burn-in (centrum helderder)

ANIMATIES
  warmupEnabled       bool           CRT warmup-animatie bij openen venster
  warmupDuration      float 0.5–30   Duur in seconden
  degaussOnStart      bool           Degauss-animatie bij openen venster
  degaussDuration     float 0.5–10   Duur in seconden

