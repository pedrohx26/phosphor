CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
    install)           cmd_install           ;;
    uninstall)         cmd_uninstall         ;;
    install-fonts)     cmd_install_fonts "$@";;
    check)             cmd_check             ;;
    on|enable)         cmd_on                ;;
    off|disable)       cmd_off               ;;
    toggle)            cmd_toggle            ;;
    status)            cmd_status            ;;
    preset)            cmd_preset "$@"       ;;
    presets)           cmd_presets           ;;
    set)               cmd_set "$@"          ;;
    get)               cmd_get "$@"          ;;
    reset)             cmd_reset             ;;
    degauss)           cmd_degauss           ;;
    params)            cmd_params            ;;
    readme)            cmd_readme            ;;
    help|--help|-h)    cmd_help              ;;
    *)  err "Onbekend commando: $CMD"
        echo ""
        cmd_help
        exit 1
        ;;
esac
