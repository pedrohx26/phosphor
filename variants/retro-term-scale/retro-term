    cat <<'EOF'

PARAMETER REFERENTIE — retro-term
══════════════════════════════════════════════════════════════════

FOSFORY & KLEUR
  phosphorType        int   0–3      0=P1 helder groen, 1=P3 amber, 2=P4 wit, 3=P39 radar
  phosphorAgeing      float 0.0–1.0  Vergeeling van oud fosfor (0=nieuw, 1=verweerd)
  colorTemperature    float 3000–9300 Kelvin: 3000=warm geel, 9300=koud blauw-wit
  phosphorPersistence float 0.0–1.0  Nagloed: hoe lang tekens zichtbaar blijven

