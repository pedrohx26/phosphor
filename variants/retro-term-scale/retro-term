  ambientReflection   float 0.0–0.30 Spiegelreflectie van schermglas

SCANLINES
  rasterizationMode   int   0–3      0=geen, 1=scanlines, 2=pixelraster, 3=sub-pixel RGB
  scanlinesIntensity  float 0.0–1.0  Zichtbaarheid van scanlines
  scanlinesSharpness  float 0.0–1.0  Scherpte van scanline-randen

BLOOM & GLOED
  bloom               float 0.0–1.0  Gloedhalo rond heldere pixels (13-tap Gaussian)
  glowingLine         float 0.0–1.0  Horizontale lijngloed
  brightness          float 0.0–1.0  Algehele helderheid
  contrast            float 0.0–1.0  Contrast

RUIS & SYNCHRONISATIE
  staticNoise         float 0.0–1.0  Statische beeldruis
  jitter              float 0.0–1.0  Willekeurige pixelverschuiving
