# ══════════════════════════════════════════════════════════════════════════════
# INSTALL / UNINSTALL
# ══════════════════════════════════════════════════════════════════════════════
cmd_install() {
    head "Effect installeren"
    mkdir -p "$EFFECT_DIR/contents/shaders" "$EFFECT_DIR/contents/code"
    write_shader
    write_effect_js
    write_metadata
    write_default_config
    ok "Bestanden geïnstalleerd in $EFFECT_DIR"
    info "Voer uit om te activeren: ${BOLD}retro-term on${NC}"
}

cmd_uninstall() {
    head "Effect verwijderen"
    [[ -d "$EFFECT_DIR" ]] && { rm -rf "$EFFECT_DIR"; ok "Effect-bestanden verwijderd"; } \
                            || info "Effect was niet geïnstalleerd"
    cmd_off 2>/dev/null || true
    info "Config-sectie in kwinrc blijft bewaard (handmatig verwijderen indien gewenst)"
}

# ══════════════════════════════════════════════════════════════════════════════
# AAN / UIT / TOGGLE / STATUS
# ══════════════════════════════════════════════════════════════════════════════
cmd_on() {
    [[ -d "$EFFECT_DIR" ]] || die "Effect niet geïnstalleerd. Voer eerst: retro-term install"
    kwriteconfig6 --file kwinrc --group Plugins --key "${EFFECT_ID}Enabled" "true"
    kwin_reload
    ok "Effect geactiveerd"
}

cmd_off() {
    kwriteconfig6 --file kwinrc --group Plugins --key "${EFFECT_ID}Enabled" "false"
    kwin_reload
    ok "Effect gedeactiveerd"
}

cmd_toggle() {
    local state
    state=$(kreadconfig6 --file kwinrc --group Plugins --key "${EFFECT_ID}Enabled" 2>/dev/null || echo "false")
    if [[ "$state" == "true" ]]; then
        cmd_off
    else
        cmd_on
    fi
}

cmd_status() {
    head "Status"
    local enabled
    enabled=$(kreadconfig6 --file kwinrc --group Plugins --key "${EFFECT_ID}Enabled" 2>/dev/null || echo "false")
    if [[ "$enabled" == "true" ]]; then
        msg "  Effect:  ${G}${BOLD}AAN${NC}"
    else
        msg "  Effect:  ${R}${BOLD}UIT${NC}"
    fi

    local installed="nee"
    [[ -f "$EFFECT_DIR/contents/shaders/retro.frag" ]] && installed="ja"
    msg "  Install: $installed  ${DIM}($EFFECT_DIR)${NC}"

    local preset
    preset=$(kread activePreset)
    msg "  Preset:  ${preset:-${DIM}(geen)${NC}}"
    echo ""
    head "Actieve instellingen"
    local keys=(phosphorType phosphorAgeing colorTemperature screenCurvature
                rasterizationMode bloom brightness contrast staticNoise
                syncMode warmupEnabled degaussOnStart targetClasses)
    for k in "${keys[@]}"; do
        local v; v=$(kread "$k")
        printf "  ${DIM}%-22s${NC} %s\n" "$k" "${v:-(standaard)}"
    done
}

# ══════════════════════════════════════════════════════════════════════════════
# SET / GET / RESET
# ══════════════════════════════════════════════════════════════════════════════
cmd_set() {
    [[ $# -ge 2 ]] || die "Gebruik: retro-term set <parameter> <waarde>"
    kwrite "$1" "$2"
    ok "Ingesteld: $1 = $2"
    kwin_reload
}

cmd_get() {
    if [[ $# -eq 0 ]]; then
        head "Alle instellingen"
        grep -A 60 "\[$CFG_GROUP\]" "$KWINRC" 2>/dev/null | grep -v "^\[" | grep "=" | \
            while IFS='=' read -r k v; do
                printf "  ${C}%-24s${NC} %s\n" "${k// /}" "${v// /}"
            done || info "Geen instellingen gevonden in kwinrc"
    else
        local v; v=$(kread "$1")
        echo "$1 = ${v:-(niet ingesteld / standaard)}"
    fi
}

cmd_reset() {
    head "Instellingen terugzetten naar standaard"
    # Verwijder de sectie en herschrijf
    if grep -q "\[$CFG_GROUP\]" "$KWINRC" 2>/dev/null; then
        python3 -c "
import re, sys
txt=open('$KWINRC').read()
txt=re.sub(r'\n\[$CFG_GROUP\][^\[]*','',txt,flags=re.DOTALL)
open('$KWINRC','w').write(txt)
" 2>/dev/null || {
            warn "Python3 niet beschikbaar — handmatig verwijderen uit $KWINRC"
            return 1
        }
    fi
    write_default_config
    kwin_reload
    ok "Instellingen teruggezet naar standaard"
}

