#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  retro-term  —  KWin CRT-shader effect voor KDE Plasma 6                  ║
# ║  Eén script voor: installatie, fonts, presets, instellingen, aan/uit       ║
# ╚══════════════════════════════════════════════════════════════════════════════╝
#
# Gebruik:  retro-term <commando> [opties]
# Versie:   2.0
# Licentie: GPL-2.0-or-later
set -euo pipefail

# ── Kleurcodes ─────────────────────────────────────────────────────────────────
R='\033[0;31m' G='\033[0;32m' Y='\033[1;33m' C='\033[0;36m'
B='\033[0;34m' M='\033[0;35m' BOLD='\033[1m' DIM='\033[2m' NC='\033[0m'
TICK="${G}✓${NC}" CROSS="${R}✗${NC}" ARROW="${C}→${NC}" WARN="${Y}!${NC}"

# ── Paden ──────────────────────────────────────────────────────────────────────
EFFECT_ID="retro-terminal"
EFFECT_DIR="$HOME/.local/share/kwin/effects/$EFFECT_ID"
FONT_DIR="$HOME/.local/share/fonts/retro-terminal"
KONSOLE_DIR="$HOME/.local/share/konsole"
KWINRC="$HOME/.config/kwinrc"
CFG_GROUP="Effect-retro-terminal"
SELF="$(realpath "${BASH_SOURCE[0]}")"

# ── Helperfuncties ─────────────────────────────────────────────────────────────
msg()  { echo -e "$*"; }
info() { echo -e "${C}[info]${NC} $*"; }
ok()   { echo -e "${G}[ ok ]${NC} $*"; }
warn() { echo -e "${Y}[warn]${NC} $*"; }
err()  { echo -e "${R}[fout]${NC} $*" >&2; }
die()  { err "$*"; exit 1; }
sep()  { echo -e "${DIM}──────────────────────────────────────────────────────${NC}"; }
head() { echo -e "\n${BOLD}${C}$*${NC}"; }

kread()  { kreadconfig6  --file kwinrc --group "$CFG_GROUP" --key "$1" 2>/dev/null || echo ""; }
kwrite() { kwriteconfig6 --file kwinrc --group "$CFG_GROUP" --key "$1" "$2"; }
kwin_reload() {
    qdbus6 org.kde.KWin /KWin reconfigure 2>/dev/null ||
    qdbus  org.kde.KWin /KWin reconfigure 2>/dev/null ||
    warn "KWin D-Bus niet bereikbaar — herstart KWin handmatig (kwin --replace &)"
}

need() { command -v "$1" &>/dev/null || die "Vereist: $1 — installeer via: sudo pacman -S $2"; }
has()  { command -v "$1" &>/dev/null; }
font_present() { fc-list 2>/dev/null | grep -qi "${1%%,*}"; }

download() {
    local url="$1" dest="$2" desc="${3:-bestand}"
    info "Downloaden: $desc"
    if has curl; then
        curl -fsSL --progress-bar "$url" -o "$dest" && return 0
    elif has wget; then
        wget -q --show-progress "$url" -O "$dest" && return 0
    fi
    warn "Download mislukt: $url"
    return 1
}

